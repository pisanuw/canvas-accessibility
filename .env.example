# ─────────────────────────────────────────────────────────────────────────────
# Canvas Accessibility Fixer — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────

# Secret key used to sign session cookies.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ── User Login ────────────────────────────────────────────────────────────────

# Credentials for the main tool (faculty/staff who run fixes).
APP_USERNAME=change-to-a-username-for-faculty-staff
APP_PASSWORD=change-to-a-password-for-faculty-staff

# ── Canvas Instance Restrictions ─────────────────────────────────────────────

# Primary Canvas base URL used for API calls and generated links.
CANVAS_BASE_URL=https://canvas.uw.edu

# Comma-separated allowlist for accepted course URL bases on Step 1.
# If empty, only CANVAS_BASE_URL is accepted.
# Example: https://canvas.uw.edu,https://canvas.test.uw.edu
CANVAS_ALLOWED_BASE_URLS=

# Ally external tool ID used for dashboard links (UW default shown).
ALLY_TOOL_ID=148172

# ── Admin Login ───────────────────────────────────────────────────────────────

# Credentials for the /admin dashboard (run log, report downloads).
ADMIN_USERNAME=change-to-an-admin-username
ADMIN_PASSWORD=change-to-an-admin-password

# ── Email Notifications (Resend) ──────────────────────────────────────────────

# Resend API key — get one at https://resend.com/api-keys
# If not set, email notifications are silently skipped.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Address that receives a notification + HTML report after each fix run.
ADMIN_EMAIL=change-to-actual-email-for-notifications

# Sender address — must be a verified domain in your Resend account.
# The free tier allows onboarding@resend.dev for testing.
FROM_EMAIL=some-noreply-email

# ── Deployment (Render / Gunicorn) ────────────────────────────────────────────

# Set automatically by Render; only needed for local HTTPS testing.
# PORT=5000
